# Production Environment Variables Template
# Copy this file to .env and update with production values

# Database Configuration
DB_HOST=localhost
DB_NAME=AMS
DB_USER=ams_user
DB_PASSWORD=your_secure_password_here
DB_PORT=3306
DB_ROOT_PASSWORD=your_root_password_here

# JWT Configuration
JWT_SECRET_KEY=your_very_long_secret_key_here_make_it_at_least_32_characters
JWT_ISSUER=https://fixedasset.29jewellery.com
JWT_AUDIENCE=https://fixedasset.29jewellery.com

# Admin Configuration
ADMIN_PASSWORD=your-strong-admin-password-here

# Application Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80;https://+:443

# Email Configuration (Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your_email@gmail.com

# AWS Configuration (if using AWS services)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Optional: Custom Domain
CUSTOM_DOMAIN=fixedasset.29jewellery.com
SSL_CERTIFICATE_PATH=/etc/letsencrypt/live/fixedasset.29jewellery.com/fullchain.pem
SSL_PRIVATE_KEY_PATH=/etc/letsencrypt/live/fixedasset.29jewellery.com/privkey.pem

# Security Configuration
ENABLE_HTTPS_REDIRECTION=true
ENABLE_SECURITY_HEADERS=true
